# PostgreSQL credentials (used by both the db container and the backend DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=taskmanager

# Database - local dev; Docker overrides this to use the db service hostname
DATABASE_URL=postgres://postgres:change-me-in-production@localhost:5432/taskmanager?sslmode=disable

# Backend
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=8080
FRONTEND_URL=http://localhost:3000

# AWS S3 (file attachments - leave blank to disable)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
